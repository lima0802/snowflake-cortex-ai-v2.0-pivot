# ==============================================================================
# DIA v2 — Environment Configuration (v2.0-β)
# ==============================================================================
# Copy this to .env and fill in your values.
#
# v2.0-β model strategy: single OpenAI API key for all LLM capabilities.
# Swap provider by changing LLM_PROVIDER — zero code changes required.

# --- LLM Provider ---
# Options: "openai" | "google" | "together" | "groq"
LLM_PROVIDER=openai

# --- OpenAI (PRIMARY — demo default) ---
# GPT-4o: Text-to-SQL (BIRD-SQL 81.95% EX) + Response Synthesis
# GPT-4o-mini: Intent Classification (fast, $0.15/1M tokens)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_SQL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SYNTHESIS=gpt-4o

# --- Google Gemini (FALLBACK A) ---
# GOOGLE_API_KEY=...
# GOOGLE_MODEL_SQL=gemini/gemini-2.5-pro
# GOOGLE_MODEL_FAST=gemini/gemini-2.5-flash
# GOOGLE_MODEL_SYNTHESIS=gemini/gemini-2.5-pro

# --- Together AI / open-source (FALLBACK B — post-budget self-hosted path) ---
# TOGETHER_API_KEY=...
# TOGETHER_MODEL_SQL=together_ai/deepseek-ai/DeepSeek-V3
# TOGETHER_MODEL_FAST=together_ai/meta-llama/Llama-3.1-8B-Instruct-Turbo
# TOGETHER_MODEL_SYNTHESIS=together_ai/mistralai/Mistral-Large-Instruct-2407

# --- Groq (FALLBACK C — ultra-low latency) ---
# GROQ_API_KEY=...
# GROQ_MODEL_FAST=groq/llama-3.1-8b-instant

# --- Embedding Model ---
# v2.0-β: text-embedding-3-small (OpenAI) — same API key, $0.02/1M tokens
# Set EMBEDDING_PROVIDER=local to use BGE-M3 via sentence-transformers (no API key)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=local
# EMBEDDING_LOCAL_MODEL=BAAI/bge-m3

# --- Snowflake Connection ---
SNOWFLAKE_ACCOUNT=fvqlqib-tj68700
SNOWFLAKE_USER=LIMA
SNOWFLAKE_PASSWORD=Easy2snowflake!
SNOWFLAKE_WAREHOUSE=TEST
SNOWFLAKE_DATABASE=PLAYGROUND_LM
SNOWFLAKE_SCHEMA=CORTEX_ANALYTICS_ORCHESTRATOR
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_SEMANTIC_STAGE=SEMANTIC_MODELS

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
STREAMLIT_PORT=8501
DEBUG=true

# --- Demo Mode ---
# When true, falls back to cached responses if live query fails
DEMO_FALLBACK_ENABLED=true
