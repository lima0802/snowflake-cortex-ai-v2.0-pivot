# DIA v2 — Streamlit Cloud Secrets
# Copy this to .streamlit/secrets.toml for local use,
# or paste each value into the Streamlit Cloud "Secrets" UI.
# Never commit secrets.toml to git.

# LLM
OPENAI_API_KEY = "sk-..."

# Snowflake
SNOWFLAKE_ACCOUNT   = "your-account.region"
SNOWFLAKE_USER      = "your_user"
SNOWFLAKE_PASSWORD  = "your_password"
SNOWFLAKE_WAREHOUSE = "DIA_WH"
SNOWFLAKE_DATABASE  = "DEV_MARCOM_DB"
SNOWFLAKE_SCHEMA    = "CORTEX_ANALYTICS_ORCHESTRATOR"
SNOWFLAKE_ROLE      = "DIA_ANALYST_ROLE"

# App
DIA_MODE = "direct"
